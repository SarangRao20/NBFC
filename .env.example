# NBFC Loan System Environment Configuration

# Development Settings
DEBUG=true
DISABLE_OTP=true
DEV_OTP=123456

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600

# Email Configuration (Configure for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@finserve-nbfc.com
EMAIL_FROM_NAME=FinServe NBFC

# File Storage
UPLOAD_DIR=data/uploads
SANCTION_DIR=data/sanctions

# Underwriting Thresholds
MIN_CREDIT_SCORE=700
MAX_DTI_RATIO=0.50
MAX_EXPOSURE_MULTIPLIER=2.0

# Persuasion Loop
MAX_NEGOTIATION_ROUNDS=3

# Profile Completeness
REQUIRED_PROFILE_FIELDS=["name", "phone", "email", "city", "salary", "credit_score", "existing_emi_total"]
